{
  "name": "z2m-lite",
  "version": "1.6.0",
  "description": "Logs, stores & provides API for MQTT events",
  "main": "./dist/server.js",
  "scripts": {
    "www": "cd ./src/www && npm run --",
    "build": "tsc && npm run www build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "ls -l && cd ./src/www && npm i",
    "dockerize": "docker build -t z2m .",
    "docker-run": "docker run -d -p 8088:8088 -p 8443:8443 -p 1883:1883 --name z2m-lite z2m"
  },
  "type": "commonjs",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@elastic/elasticsearch": "^7.17.14",
    "aedes": "^0.51.3",
    "aedes-persistence": "^9.1.2",
    "mqtt": "^4.3.7",
    "node-static": "^0.7.11",
    "ws": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.70",
    "@types/node-static": "^0.7.7",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
